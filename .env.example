# Pawvy Environment Variables
# Copy this file to .env. These defaults work out of the box for local dev.

# ===========================================
# Local Dev Defaults (desktop + browser on same machine)
# ===========================================

# Shared API key (frontend and backend both read this from root .env)
# Use a non-default value in local/prod environments.
PAWVY_API_KEY=replace-with-strong-key

# Bind backend on LAN-friendly interface
HOST=0.0.0.0
PORT=3001

# Production Port
# PAWVY_PORT=3002

# Keep frontend URLs relative by default.
# This works with Vite dev proxy and production static serving.
API_BASE=
WS_BASE=

# Optional domain used by reverse proxies (for example, Traefik Host() routing).
# PAWVY_HOST=pawvy.localhost

# Optional Traefik settings (used by compose.traefik.yaml override)
# TRAEFIK_DOCKER_NETWORK=proxy
# TRAEFIK_ENTRYPOINTS=websecure
# TRAEFIK_TLS=true

# ===========================================
# Optional - Storage / Project Discovery
# ===========================================

# Data directory (relative to compose file, or absolute host path)
# Default: ./data
# PAWVY_DATA_DIR=./data

# Projects directory to scan on host (mounted read-only into container)
# Default: $HOME/.pawvy/projects
# PAWVY_PROJECTS_DIR=/absolute/path/to/projects

# OpenClaw home directory on host (mounted read-only into container)
# Default: $HOME/.openclaw
# OPENCLAW_HOME=/absolute/path/to/openclaw

# ===========================================
# Optional - Mobile / LAN Access
# ===========================================

# If desktop works but mobile gets stuck reconnecting, point frontend directly
# to backend on LAN IP (replace with your machine IP):
# API_BASE=http://192.168.1.10:3001
# WS_BASE=ws://192.168.1.10:3001/ws
# If frontend is served over HTTPS, use wss:// for WS_BASE.

# ===========================================
# Optional - OpenClaw Integration
# ===========================================

# Include only selected agents in Pawvy UI/events (comma-separated)
# PAWVY_AGENTS_INCLUDE=tee,fay

# Optional path to Pawvy config JSON (default: ~/.pawvy/config.json)
# PAWVY_CONFIG_PATH=/path/to/pawvy-config.json
